{
	"name": "fuiz-website",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"bun": ">=1.2.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome format && biome check && eslint .",
		"lint:fix": "biome format --write && biome check --write && eslint . --fix",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"lang": "bun run lang:check && bun run lang:untranslated && bun run lang:unused",
		"lang:check": "node scripts/check-messages.js",
		"lang:untranslated": "node scripts/find-untranslated.js",
		"lang:unused": "node scripts/find-unused-messages.js"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@eslint/compat": "^2.1.0",
		"@iconify-json/material-symbols": "^1.2.76",
		"@inlang/paraglide-js": "^2.18.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.2",
		"@types/object-hash": "^3.0.6",
		"eslint": "^10.4.1",
		"eslint-plugin-svelte": "^3.19.0",
		"super-sitemap": "^1.0.12",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-dnd-action": "^0.9.69",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"wrangler": "^4.98.0"
	},
	"dependencies": {
		"@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@fontsource-variable/noto-sans-arabic": "^5.2.10",
		"@fontsource/poppins": "^5.2.7",
		"@oddbird/popover-polyfill": "^0.6.1",
		"@thisux/sveltednd": "^0.4.1",
		"interestfor": "^1.0.8",
		"jszip": "^3.10.1",
		"object-hash": "^3.0.0",
		"smol-toml": "^1.6.1",
		"svelte-confetti": "^2.3.2",
		"uuid": "^14.0.0"
	}
}
